# CLI 环境变量（复制为 .env 后按需 export，CLI 不会自动加载 dotenv）
#
# 启动示例：
#   set -a && source packages/cli/.env && set +a && pnpm dev:cli
#
# 远程 / 局域网：MUSE_CLI_HOST 必须是浏览器能访问的地址，不要用 0.0.0.0 代填。
# 详见 docs/development-guide.md「远程 CLI 与局域网」

# daemon 监听地址；同时用于配对/心跳注册到 Backend 的 endpoint host
# 局域网示例：MUSE_CLI_HOST=192.168.1.100
MUSE_CLI_HOST=127.0.0.1

# daemon 端口
MUSE_CLI_PORT=65433

# 允许跨域的 Web 来源（逗号分隔，须含浏览器地址栏完整 origin）
# 局域网示例：MUSE_CORS_ORIGINS=http://192.168.1.50:65434,http://127.0.0.1:65434
# MUSE_CORS_ORIGINS=http://localhost:65434,http://127.0.0.1:65434

# 本地数据目录（测试可指向临时目录）
# MUSE_HOME=/tmp/muse-test
