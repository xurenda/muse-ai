# Server 环境变量（复制为 .env 后按需修改）
PORT=65435
HOST=127.0.0.1

# Docker Compose 默认（packages/server/docker-compose.yml）
DATABASE_URL=postgresql://muse:muse@localhost:5432/muse
REDIS_URL=redis://localhost:6379

# 鉴权与加密（开发用占位值，生产务必更换）
JWT_SECRET=dev-jwt-secret-change-in-production
# 32 字节 hex（64 字符），用于 AES-256-GCM 加密 Provider API Key
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Web 跨域（逗号分隔）；默认允许 localhost:65434
# MUSE_CORS_ORIGINS=http://localhost:65434,http://127.0.0.1:65434

# 市场 .musepack 本地存储（默认 packages/server/data/market）
# MARKET_DATA_DIR=./data/market

# 对外可访问的 Server 根 URL（生成 downloadUrl；默认 http://HOST:PORT）
# PUBLIC_BASE_URL=http://127.0.0.1:65435
