    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@muse-ai/shared": "workspace:*",
    "@hono/node-server": "^1.19.3",
    "hono": "^4.9.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
