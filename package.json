{
  "name": "@museai/root",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:cli": "pnpm --filter @museai/cli dev",
    "muse": "pnpm --filter @museai/cli exec tsx src/cli.ts",
    "dev:server": "pnpm --filter @museai/server dev",
    "dev:web": "pnpm --filter @museai/shared build && pnpm --filter @museai/web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "pnpm build && vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@10.12.1"
}
